# Secret boundary (R25): only the NEXT_PUBLIC_* vars below — the VAPID PUBLIC key and the app URL —
# reach the browser, and both are non-secret by design. Everything else is server-only and must
# never be prefixed NEXT_PUBLIC_ or logged.

# Supabase Postgres — TRANSACTION POOLER connection string (Project -> Connect -> Transaction pooler).
# Shape: postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Shared secret for the reconcile route (constant-time compared). Use a long random string.
CRON_SECRET=

# AeroDataBox flight status (runtime only; unit tests use fixtures).
# Geocoding + transit use keyless OpenStreetMap (Nominatim + OSRM) — no key needed.
AERODATABOX_KEY=

# Public origin of the app, e.g. https://keeper.example.com (NO trailing slash). Used to build the
# absolute deep-links inside push notifications; dispatch FAILS LOUD in production when it's unset (a
# relative URL is unopenable from a push client). Optional in dev — falls back to a relative path.
NEXT_PUBLIC_APP_URL=

# Web Push (VAPID). Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Public absolute base URL of the app (origin), e.g. https://keeper.app — NO trailing slash.
# Used to build the absolute dashboard deep-link inside push notification payloads. REQUIRED in
# production (push dispatch fails loud if unset there, like the VAPID check); optional in dev, where
# it falls back to a relative path. NEXT_PUBLIC_ on purpose — it is a public origin, never a secret.
NEXT_PUBLIC_APP_URL=

# Upstash Redis (U11 abuse controls / rate limiting). Optional until U11.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
